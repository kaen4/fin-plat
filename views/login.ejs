<!DOCTYPE html>
<html lang="<%= lang || 'ru' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('login') %> | <%= t('app_name') %></title>
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #eef2ff 0%, #f5f7fb 50%, #ede9fe 100%);
            color: #222;
            min-height: 100vh;
        }

        .page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
            box-sizing: border-box;
        }

        .auth-layout {
            width: 100%;
            max-width: 1050px;
            display: grid;
            grid-template-columns: 1.1fr 0.9fr;
            gap: 24px;
            align-items: stretch;
        }

        .promo-card {
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
            color: white;
            border-radius: 24px;
            padding: 36px;
            box-shadow: 0 18px 50px rgba(79, 70, 229, 0.25);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .promo-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
            flex-wrap: wrap;
        }

        .brand {
            font-size: 30px;
            font-weight: 800;
            margin: 0;
        }

        .lang-switcher {
            display: flex;
            gap: 8px;
        }

        .lang-switcher a {
            text-decoration: none;
            padding: 8px 12px;
            border-radius: 10px;
            background: rgba(255,255,255,0.16);
            color: white;
            font-size: 14px;
            border: 1px solid rgba(255,255,255,0.18);
        }

        .lang-switcher a.active {
            background: white;
            color: #4f46e5;
            font-weight: 700;
        }

        .promo-content {
            margin-top: 36px;
        }

        .promo-content h2 {
            margin: 0 0 12px 0;
            font-size: 34px;
            line-height: 1.15;
        }

        .promo-content p {
            margin: 0;
            font-size: 16px;
            line-height: 1.7;
            opacity: 0.94;
            max-width: 540px;
        }

        .promo-points {
            margin-top: 28px;
            display: grid;
            gap: 12px;
        }

        .promo-point {
            background: rgba(255,255,255,0.12);
            border: 1px solid rgba(255,255,255,0.14);
            border-radius: 14px;
            padding: 14px 16px;
            font-size: 15px;
        }

        .auth-card {
            background: #fff;
            border-radius: 24px;
            padding: 32px;
            box-shadow: 0 18px 50px rgba(15, 23, 42, 0.10);
        }

        .auth-header h2 {
            margin: 0 0 8px 0;
            font-size: 30px;
        }

        .auth-header p {
            margin: 0 0 24px 0;
            color: #666;
            line-height: 1.6;
        }

        .error-box {
            margin-bottom: 18px;
            padding: 12px 14px;
            border-radius: 12px;
            background: #fee2e2;
            color: #991b1b;
            font-size: 14px;
            font-weight: 600;
        }

        .form-group {
            margin-bottom: 16px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            color: #555;
            font-weight: 700;
            font-size: 14px;
        }

        input {
            width: 100%;
            padding: 12px 13px;
            border: 1px solid #d7dce3;
            border-radius: 12px;
            box-sizing: border-box;
            font-size: 15px;
            background: #fff;
        }

        input:focus {
            outline: none;
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.12);
        }

        button {
            width: 100%;
            background: #4f46e5;
            color: white;
            padding: 13px 18px;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            font-size: 15px;
            font-weight: 700;
            transition: 0.2s ease;
        }

        button:hover {
            transform: translateY(-1px);
            opacity: 0.97;
        }

        .auth-footer {
            margin-top: 18px;
            text-align: center;
            color: #666;
            font-size: 14px;
        }

        .auth-footer a {
            color: #4f46e5;
            text-decoration: none;
            font-weight: 700;
        }

        @media (max-width: 900px) {
            .auth-layout {
                grid-template-columns: 1fr;
            }

            .promo-card {
                order: 2;
            }

            .auth-card {
                order: 1;
            }
        }
    </style>
</head>
<body>
    <div class="page">
        <div class="auth-layout">
            <div class="promo-card">
                <div>
                    <div class="promo-top">
                        <h1 class="brand"><%= t('app_name') %></h1>

                        <div class="lang-switcher">
                            <a href="/login?lang=ru" class="<%= lang === 'ru' ? 'active' : '' %>">Рус</a>
                            <a href="/login?lang=kk" class="<%= lang === 'kk' ? 'active' : '' %>">Қаз</a>
                            <a href="/login?lang=en" class="<%= lang === 'en' ? 'active' : '' %>">Eng</a>
                        </div>
                    </div>

                    <div class="promo-content">
                        <h2><%= t('welcome_back') %></h2>
                        <p><%= t('login_subtitle') %></p>

                        <div class="promo-points">
                            <div class="promo-point">📊 <%= t('feature_analytics') %></div>
                            <div class="promo-point">💸 <%= t('feature_expenses') %></div>
                            <div class="promo-point">🗂️ <%= t('feature_categories') %></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="auth-card">
                <div class="auth-header">
                    <h2><%= t('login') %></h2>
                    <p><%= t('enter_account') %></p>
                </div>

                <% if (error) { %>
                    <div class="error-box"><%= error %></div>
                <% } %>

                <form action="/login" method="POST">
                    <div class="form-group">
                        <label for="username"><%= t('username') %></label>
                        <input id="username" name="username" type="text" required>
                    </div>

                    <div class="form-group">
                        <label for="password"><%= t('password') %></label>
                        <input id="password" name="password" type="password" required>
                    </div>

                    <button type="submit"><%= t('login') %></button>
                </form>

                <div class="auth-footer">
                    <%= t('no_account_yet') %>
                    <a href="/register?lang=<%= lang %>"><%= t('register') %></a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
